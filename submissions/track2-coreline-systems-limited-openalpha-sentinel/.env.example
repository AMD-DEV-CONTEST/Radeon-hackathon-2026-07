# Copy this file to .env.server. For a replacement cloud instance, only the
# following SSH host and port normally need to change.
REMOTE_SSH_HOST=CHANGE_ME
REMOTE_SSH_PORT=22
REMOTE_SSH_USER=root
REMOTE_SSH_IDENTITY_FILE=
REMOTE_SSH_STRICT=true
REMOTE_CONNECT_TIMEOUT=10

# Remote layout. Keep paths absolute and free of whitespace.
REMOTE_PROJECT_DIR=/workspace/openalpha-sentinel
OPENALPHA_ROOT=/workspace/openalpha-sentinel
OPENALPHA_DATA_DIR=/workspace/openalpha-data/runtime
OPENALPHA_RUN_DIR=/workspace/openalpha-state/run
OPENALPHA_LOG_DIR=/workspace/openalpha-state/logs
OUTPUT_DIR=/workspace/openalpha-artifacts/benchmarks

# Browser access uses an SSH tunnel by default.
LOCAL_TUNNEL_PORT=8765
OPENALPHA_HOST=127.0.0.1
OPENALPHA_PORT=8765
OPENALPHA_OFFLINE=false
OPENALPHA_ALLOWED_DOMAINS=api.github.com,github.com,raw.githubusercontent.com

# Local model backend: auto | heuristic | ollama | llama_cpp
OPENALPHA_LLM_BACKEND=llama_cpp
OPENALPHA_OLLAMA_URL=http://127.0.0.1:11434
OPENALPHA_OLLAMA_MODEL=mistral:latest
OPENALPHA_LLAMA_URL=http://127.0.0.1:8080/v1
OPENALPHA_LLAMA_MODEL=qwen3-8b

# ROCm llama.cpp build and runtime.
LLAMA_REPOSITORY=https://github.com/ROCm/llama.cpp.git
LLAMA_COMMIT=1b99711a5f2582ec99686eb7958844749c223cf5
LLAMA_ARCHIVE_URL=https://codeload.github.com/ROCm/llama.cpp/tar.gz/1b99711a5f2582ec99686eb7958844749c223cf5
LLAMA_ARCHIVE_SHA256=65536629d57a7b7f9ec81a323311dd497e09a5d8b981225c6c56feda63cefde4
LLAMA_ARCHIVE_PATH=/workspace/cache/llama.cpp-1b99711a5f2582ec99686eb7958844749c223cf5.tar.gz
LLAMA_SOURCE=/workspace/llama.cpp
LLAMA_BUILD=/workspace/llama.cpp/build
LLAMA_BIN=/workspace/llama.cpp/build/bin/llama-server
LLAMA_BENCH=/workspace/llama.cpp/build/bin/llama-bench
LLAMA_HOST=127.0.0.1
LLAMA_PORT=8080
LLAMA_CTX=8192
LLAMA_GPU_LAYERS=99
LLAMA_LOG_VERBOSITY=4
AMDGPU_TARGETS=gfx1100
BUILD_JOBS=16

# Put optional local transfer sources here. Empty values use a remote clone or
# require the model to have already been placed at MODEL_PATH.
LOCAL_LLAMA_SOURCE=./data/vendor/llama.cpp
LOCAL_LLAMA_ARCHIVE=./data/vendor/llama.cpp-1b99711a5f2582ec99686eb7958844749c223cf5.tar.gz
MODEL_LOCAL_PATH=./models/Qwen3-8B-Q4_K_M.gguf
MODEL_DOWNLOAD_URL=https://modelscope.cn/models/Qwen/Qwen3-8B-GGUF/resolve/master/Qwen3-8B-Q4_K_M.gguf
MODEL_PATH=/workspace/models/Qwen3-8B-Q4_K_M.gguf
MODEL_SHA256=d98cdcbd03e17ce47681435b5150e34c1417f50b5c0019dd560e4882c5745785

# Remote lifecycle. auto uses systemd when it is online, otherwise nohup/PIDs.
SERVER_SERVICE_MODE=auto
SERVER_START_COMPONENTS=llama,api,worker
SERVER_START_TIMEOUT=180
SERVER_STOP_TIMEOUT=20
SERVER_LOCK_TIMEOUT=30
SERVER_INSTALL_PACKAGES=true
SERVER_INSTALL_EXTRAS=dev
SERVER_BACKUP_DIR=./data/server-backups
PYTHON_BIN=python3.12

# Public-source collection. A token is optional but raises GitHub rate limits.
GITHUB_TOKEN=
OPENALPHA_USER_AGENT="OpenAlpha-Sentinel/0.1 (+https://github.com/)"
OPENALPHA_MAX_DOCUMENT_BYTES=2000000
OPENALPHA_WORKER_POLL_SECONDS=15
