      "document_id": "nvda-2025-10k",
      "section": "Note 1. Revenue Concentration",
      "page": 58,
      "locator": "direct-customers",
      "periods": [
        "FY2025"
      ],
      "text": "Three direct NVIDIA customers represented 12 percent, 11 percent, and 11 percent of fiscal 2025 revenue, primarily in Compute and Networking."
    },
    {
