      "locator": "supply-chain-geography",
      "periods": [
        "FY2025"
      ],
      "text": "NVIDIA's supply chain is mainly concentrated in Asia-Pacific and depends on external foundries, memory suppliers, assembly, testing, and contract manufacturers."
    },
    {
      "chunk_id": "nvda-rate-risk",
      "document_id": "nvda-2025-10k",
      "section": "Item 7A. Market Risk",
      "page": 45,
      "locator": "investment-interest-rate-risk",
      "periods": [
