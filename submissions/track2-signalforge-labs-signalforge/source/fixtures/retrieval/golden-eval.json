      "page": 28,
      "locator": "export-controls",
      "periods": [
        "FY2025"
      ],
      "text": "AI semiconductor export controls can restrict NVIDIA sales, impair demand, disrupt supply and distribution, advantage competitors, and create excess inventory charges."
    },
