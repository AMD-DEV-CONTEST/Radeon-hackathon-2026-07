      "chunk_id": "msft-business-model",
      "document_id": "msft-2025-10k",
      "section": "Item 1. Business",
      "page": 5,
      "locator": "business-overview",
      "periods": [
        "FY2025"
      ],
      "text": "Microsoft generates revenue from cloud solutions and services, software licensing and support, online advertising, and devices. Its major costs include employees and datacenter operations."
    },
    {
      "chunk_id": "msft-segments",
      "document_id": "msft-2025-10k",
      "section": "Item 7. Management's Discussion and Analysis",
      "page": 37,
      "locator": "reportable-segments",
      "periods": [
        "FY2025"
      ],
      "text": "Microsoft reports three segments: Productivity and Business Processes, Intelligent Cloud, and More Personal Computing."
    },
    {
      "chunk_id": "msft-azure-growth",
      "document_id": "msft-2025-10k",
      "section": "Item 7. Segment Results",
      "page": 39,
      "locator": "intelligent-cloud-results",
      "periods": [
        "FY2025",
        "FY2024"
      ],
      "text": "Azure and other cloud services revenue grew 34 percent in fiscal 2025, driven by demand for Microsoft's portfolio of services."
    },
    {
      "chunk_id": "msft-cloud-margin",
      "document_id": "msft-2025-10k",
      "section": "Item 7. Results of Operations",
      "page": 38,
      "locator": "microsoft-cloud-gross-margin",
      "periods": [
        "FY2025",
        "FY2024"
      ],
      "claim_key": "msft.cloud_margin_driver.fy2025",
      "claim_value": "ai_infrastructure_pressure_offset_by_azure_efficiency",
      "text": "Microsoft Cloud gross margin percentage declined to 69 percent because of scaling AI infrastructure, partly offset by Azure efficiency gains."
    },
    {
      "chunk_id": "msft-capex",
      "document_id": "msft-2025-10k",
      "section": "Item 7. Liquidity and Capital Resources",
      "page": 46,
      "locator": "other-planned-uses-of-capital",
      "periods": [
        "FY2025"
      ],
      "text": "Microsoft plans continued capital expenditures for cloud growth, AI infrastructure, and training, including datacenters and computer systems."
    },
    {
      "chunk_id": "msft-purchase-commitments",
      "document_id": "msft-2025-10k",
      "section": "Item 7. Contractual Obligations",
      "page": 45,
      "locator": "purchase-commitments",
      "periods": [
        "FY2026",
        "thereafter"
      ],
      "text": "Microsoft's purchase commitments primarily concern datacenters and include open purchase orders and take-or-pay contracts."
    },
    {
      "chunk_id": "msft-fx",
      "document_id": "msft-2025-10k",
      "section": "Item 7. Business Trends",
      "page": 34,
      "locator": "foreign-currency-exposure",
      "periods": [
        "FY2025"
      ],
      "text": "A significant share of Microsoft's international revenue and expenses uses non-US currencies, so exchange rates may affect results; fiscal 2025 impact was not material."
    },
    {
      "chunk_id": "msft-rpo",
      "document_id": "msft-2025-10k",
      "section": "Note 12. Unearned Revenue",
      "page": 84,
      "locator": "remaining-performance-obligations",
      "periods": [
        "2025-06-30"
      ],
      "text": "Remaining performance obligations were 375 billion dollars at June 30, 2025; 368 billion dollars related to commercial revenue."
    },
    {
      "chunk_id": "msft-cash-flow",
      "document_id": "msft-2025-10k",
      "section": "Item 7. Cash Flows",
      "page": 43,
      "locator": "cash-from-operations",
      "periods": [
        "FY2025"
      ],
      "text": "Cash from operations increased to 136.2 billion dollars in fiscal 2025, mainly from higher customer receipts, partly offset by supplier, employee, and tax payments."
    },
    {
      "chunk_id": "msft-gaming",
      "document_id": "msft-2025-10k",
      "section": "Item 7. More Personal Computing",
      "page": 40,
      "locator": "gaming-results",
      "periods": [
        "FY2025",
        "FY2024"
      ],
      "text": "Gaming revenue grew 9 percent, while Xbox hardware revenue declined 25 percent because of lower console volume."
    },
    {
      "chunk_id": "nvda-business-model",
      "document_id": "nvda-2025-10k",
      "section": "Item 1. Business",
      "page": 4,
      "locator": "our-company",
      "periods": [
        "FY2025"
      ],
      "text": "NVIDIA describes itself as a full-stack computing infrastructure company combining GPUs, networking, systems, CUDA, libraries, software, and services."
    },
    {
      "chunk_id": "nvda-segments",
      "document_id": "nvda-2025-10k",
      "section": "Item 7. Overview",
      "page": 36,
      "locator": "operating-segments",
      "periods": [
        "FY2025"
      ],
      "text": "NVIDIA has two operating segments: Compute and Networking, and Graphics."
    },
    {
      "chunk_id": "nvda-data-center-growth",
      "document_id": "nvda-2025-10k",
      "section": "Item 7. Results of Operations",
      "page": 37,
      "locator": "data-center-revenue",
      "periods": [
        "FY2025",
        "FY2024"
      ],
      "text": "NVIDIA Data Center revenue grew 142 percent in fiscal 2025, driven by Hopper demand; Blackwell production systems began shipping in the fourth quarter."
    },
    {
      "chunk_id": "nvda-gross-margin",
      "document_id": "nvda-2025-10k",
      "section": "Item 7. Gross Margin",
      "page": 39,
      "locator": "gross-margin-results",
      "periods": [
