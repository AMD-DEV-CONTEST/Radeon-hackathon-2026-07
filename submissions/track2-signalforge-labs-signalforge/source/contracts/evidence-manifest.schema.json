{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signalforge.dev/contracts/evidence-manifest.schema.json",
  "title": "SignalForge EvidenceManifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "code_commit", "code_tree_sha256", "code_dirty", "created_at", "runtime", "artifacts", "manifest_sha256"],
  "properties": {
    "schema_version": { "const": "signalforge/v1" },
    "run_id": { "$ref": "#/$defs/runID" },
    "code_commit": { "type": "string", "minLength": 1 },
    "code_tree_sha256": { "$ref": "#/$defs/sha" },
    "code_dirty": { "type": "boolean" },
    "created_at": { "type": "string", "format": "date-time" },
    "runtime": { "$ref": "#/$defs/runtime" },
    "gpu": { "$ref": "#/$defs/gpu" },
    "models": { "type": "array", "items": { "$ref": "#/$defs/model" } },
    "datasets": { "type": "array", "items": { "$ref": "#/$defs/dataset" } },
    "artifacts": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/artifact" } },
    "manifest_sha256": { "$ref": "#/$defs/sha" }
  },
  "$defs": {
    "sha": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "runID": { "type": "string", "pattern": "^[a-f0-9]{8}-[a-f0-9]{4}-7[a-f0-9]{3}-[89ab][a-f0-9]{3}-[a-f0-9]{12}$" },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "architecture"],
      "properties": {
        "os": { "type": "string", "minLength": 1 },
        "architecture": { "type": "string", "minLength": 1 },
        "go_version": { "type": "string" },
        "python_version": { "type": "string" },
        "container_image": { "type": "string" },
        "rocm_version": { "type": "string" },
        "engine_version": { "type": "string" }
      }
    },
    "gpu": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vendor", "product"],
      "properties": {
        "vendor": { "type": "string", "minLength": 1 },
        "product": { "type": "string", "minLength": 1 },
        "architecture": { "type": "string" },
        "vram_bytes": { "type": "integer", "minimum": 0 },
        "driver": { "type": "string" }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_id", "revision", "artifact_sha256", "quantization", "runtime"],
      "properties": {
        "model_id": { "type": "string", "minLength": 1 },
        "revision": { "type": "string", "minLength": 1 },
        "artifact_sha256": { "$ref": "#/$defs/sha" },
        "tokenizer_sha256": { "$ref": "#/$defs/sha" },
        "quantization": { "type": "string", "minLength": 1 },
        "runtime": { "type": "string", "minLength": 1 }
      }
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dataset_id", "version", "manifest_sha256"],
      "properties": {
        "dataset_id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "manifest_sha256": { "$ref": "#/$defs/sha" },
        "split": { "type": "string" }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "kind", "path", "sha256"],
      "properties": {
        "artifact_id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha" },
        "metrics": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    }
  }
}
