{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signalforge.dev/contracts/receipt-supersession.schema.json",
  "title": "SignalForge ReceiptSupersession v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "prior_receipt_sha256", "replacement_receipt_sha256", "reason", "created_at"],
  "properties": {
    "schema_version": { "const": "signalforge/receipt-supersession/v1" },
    "prior_receipt_sha256": { "$ref": "#/$defs/sha256" },
    "replacement_receipt_sha256": { "$ref": "#/$defs/sha256" },
    "reason": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
