{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signalforge.dev/contracts/demo-evidence.schema.json",
  "title": "SignalForge DemoEvidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "demo_id", "run_id", "scenario_id", "recorded_at", "trace_ref", "manifest_ref", "claims"],
  "properties": {
    "schema_version": { "const": "signalforge/v1" },
    "demo_id": { "type": "string", "minLength": 1 },
    "run_id": { "$ref": "evidence-manifest.schema.json#/$defs/runID" },
    "scenario_id": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "format": "date-time" },
    "video_sha256": { "$ref": "evidence-manifest.schema.json#/$defs/sha" },
    "trace_ref": { "type": "string", "minLength": 1 },
    "manifest_ref": { "type": "string", "minLength": 1 },
    "claims": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  }
}
