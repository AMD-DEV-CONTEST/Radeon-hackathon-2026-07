{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signalforge.dev/contracts/investor-relations-document-manifest.schema.json",
  "title": "SignalForge Investor Relations Document Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "documents"],
  "properties": {
    "schema_version": {"const": "signalforge/investor-relations-document-manifest/v1"},
    "documents": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/document"}
    }
  },
  "$defs": {
    "timestamp": {"type": "string", "format": "date-time"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version", "document_id", "company_id", "title", "document_type", "authority_tier",
        "issuer", "source_uri", "canonical_uri", "discovery_uri", "media_type", "language",
        "published_at", "available_at", "retrieved_at", "audited", "filed_with_sec",
        "forward_looking", "promotional", "content_sha256", "rights_class", "parser_version"
      ],
      "properties": {
        "schema_version": {"const": "signalforge/investor-relations-document/v1"},
        "document_id": {"type": "string", "minLength": 1},
        "company_id": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "document_type": {"type": "string", "minLength": 1},
        "authority_tier": {"enum": ["A", "B", "C", "D", "E"]},
        "issuer": {"type": "string", "minLength": 1},
        "source_uri": {"type": "string", "format": "uri", "pattern": "^https://"},
        "canonical_uri": {"type": "string", "format": "uri", "pattern": "^https://"},
        "discovery_uri": {"type": "string", "format": "uri", "pattern": "^https://"},
        "media_type": {"type": "string", "minLength": 1},
        "language": {"type": "string", "minLength": 2},
        "published_at": {"$ref": "#/$defs/timestamp"},
        "available_at": {"$ref": "#/$defs/timestamp"},
        "retrieved_at": {"$ref": "#/$defs/timestamp"},
        "effective_at": {"$ref": "#/$defs/timestamp"},
        "superseded_at": {"$ref": "#/$defs/timestamp"},
        "predecessor_id": {"type": "string"},
        "successor_id": {"type": "string"},
        "fiscal_period": {"type": "string"},
        "event_id": {"type": "string"},
        "speaker": {"type": "string"},
        "speaker_role": {"type": "string"},
        "audited": {"type": "boolean"},
        "filed_with_sec": {"type": "boolean"},
        "forward_looking": {"type": "boolean"},
        "promotional": {"type": "boolean"},
        "content_sha256": {"$ref": "#/$defs/sha256"},
        "rights_class": {"type": "string", "minLength": 1},
        "parser_version": {"type": "string", "minLength": 1}
      }
    }
  }
}
