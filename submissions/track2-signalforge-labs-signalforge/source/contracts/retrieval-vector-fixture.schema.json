{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signalforge.dev/contracts/retrieval-vector-fixture.schema.json",
  "title": "SignalForge Retrieval Vector Fixture v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "model_id", "revision", "dimension", "dataset_sha256", "chunks", "questions"],
  "properties": {
    "schema_version": {"const": "signalforge/retrieval-vectors/v1"},
    "model_id": {"type": "string", "minLength": 1},
    "revision": {"$ref": "#/$defs/revision"},
    "dimension": {"type": "integer", "minimum": 1},
    "dataset_sha256": {"$ref": "#/$defs/sha256"},
    "chunks": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/vector"}},
    "questions": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/vector"}}
  },
  "$defs": {
    "revision": {"type": "string", "pattern": "^[a-f0-9]{40,64}$"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "vector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "vector"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "vector": {"type": "array", "minItems": 1, "items": {"type": "number"}}
      }
    }
  }
}
