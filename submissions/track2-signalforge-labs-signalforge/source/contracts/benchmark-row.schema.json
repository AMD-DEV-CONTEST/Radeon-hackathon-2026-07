{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signalforge.dev/contracts/benchmark-row.schema.json",
  "title": "SignalForge BenchmarkRow v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "benchmark_id", "case_id", "workload_class", "started_at", "duration_ms", "success", "artifact_refs"],
  "properties": {
    "schema_version": { "const": "signalforge/v1" },
    "run_id": { "$ref": "evidence-manifest.schema.json#/$defs/runID" },
    "benchmark_id": { "type": "string", "minLength": 1 },
    "case_id": { "type": "string", "minLength": 1 },
    "workload_class": { "type": "string", "minLength": 1 },
    "model_id": { "type": "string" },
    "started_at": { "type": "string", "format": "date-time" },
    "duration_ms": { "type": "number", "minimum": 0 },
    "success": { "type": "boolean" },
    "quality": { "type": "object", "additionalProperties": { "type": "number" } },
    "runtime": { "type": "object", "additionalProperties": { "type": "number" } },
    "artifact_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  }
}
