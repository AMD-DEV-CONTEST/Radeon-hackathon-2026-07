# =============================================================================
# AMD Radeon Studio - 环境变量模板
# 复制为 .env 并填入真实值(切勿提交 .env)
# =============================================================================

# ---- Compute device override (auto-detect by default) ----
# 可选: rocm / cuda / cpu
# 留空 = 自动检测(Python:优先用 GPU,无则 CPU)
# RADEON_STUDIO_DEVICE=

# ---- HuggingFace (国内加速) ----
# HF_ENDPOINT=https://hf-mirror.com
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# ---- AMD Cloud LLM (辅助,可选) ----
# 用于 Agent 调度层,不是核心生成
# AMD_LLM_BASE_URL=https://developer.amd.com.cn/radeon/api/v1
# AMD_LLM_API_KEY=rc-xxxxxxxxxxxxxxxxxxxx
# AMD_LLM_MODEL=Qwen3.6-35B-A3B

# ---- Logging ----
# LOG_LEVEL=INFO  # DEBUG / INFO / WARNING / ERROR
